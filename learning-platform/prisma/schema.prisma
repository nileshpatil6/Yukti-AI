// This is your Prisma schema file for the AI Learning Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User model - stores user profile and preferences
model User {
  id                String     @id @default(cuid())
  email             String     @unique
  name              String
  image             String?
  age               Int?
  class             String?
  stream            String?
  learningStyle     String?    // visual, audio, examples, analogies
  pace              String?    // fast, normal, slow
  interests         String?    // JSON array of interests
  aiPersona         String?    // sci-fi robot, professor, etc.
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  subjects          Subject[]
  streak            Streak?
  achievements      Achievement[]
  studyPlans        StudyPlan[]
  quizAttempts      QuizAttempt[]
  gameSessions      GameSession[]
  flashcardReviews  FlashcardReview[]

  @@index([email])
}

// Subject model - represents a subject folder
model Subject {
  id                String     @id @default(cuid())
  userId            String
  name              String
  displayName       String
  color             String     // Theme color
  icon              String?
  fileSearchStoreId String     @unique // Gemini File Search store name
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes             Note[]
  topics            Topic[]
  quizzes           Quiz[]
  flashcardSets     FlashcardSet[]
  studySessions     StudySession[]
  milestones        Milestone[]

  @@index([userId])
}

// Note model - stores uploaded files/notes
model Note {
  id                String     @id @default(cuid())
  subjectId         String
  displayName       String
  fileName          String
  fileUrl           String     // Storage URL
  fileType          String     // pdf, image, ppt, etc.
  fileSize          Int
  fileSearchDocId   String?    // Gemini File Search document ID
  metadata          Json?      // Custom metadata for filtering
  uploadedAt        DateTime   @default(now())

  subject           Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

// Topic model - represents a topic within a subject
model Topic {
  id                String     @id @default(cuid())
  subjectId         String
  name              String
  order             Int
  description       String?
  status            String     @default("not_started") // not_started, in_progress, completed
  slidesGenerated   Boolean    @default(false)
  audioGenerated    Boolean    @default(false)
  quizGenerated     Boolean    @default(false)
  gameGenerated     Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  subject           Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  slides            Slide[]
  quizzes           Quiz[]
  games             Game[]

  @@index([subjectId])
}

// Slide model - stores presentation slides
model Slide {
  id                String     @id @default(cuid())
  topicId           String
  order             Int
  title             String
  content           Json       // Structured content (points, diagrams, etc.)
  imageUrl          String?
  audioUrl          String?    // DeepGram TTS generated audio
  notes             String?    // Speaker notes
  createdAt         DateTime   @default(now())

  topic             Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

// Quiz model - stores quizzes
model Quiz {
  id                String     @id @default(cuid())
  subjectId         String
  topicId           String?
  title             String
  difficulty        String     // easy, medium, hard
  questions         Json       // Array of question objects
  createdAt         DateTime   @default(now())

  subject           Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic             Topic?     @relation(fields: [topicId], references: [id], onDelete: SetNull)
  attempts          QuizAttempt[]

  @@index([subjectId])
  @@index([topicId])
}

// QuizAttempt model - stores quiz attempts
model QuizAttempt {
  id                String     @id @default(cuid())
  userId            String
  quizId            String
  score             Float      // Percentage
  answers           Json       // User's answers
  timeSpent         Int        // Seconds
  completedAt       DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz              Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

// Game model - stores interactive games
model Game {
  id                String     @id @default(cuid())
  topicId           String
  title             String
  description       String
  htmlContent       String     // Full HTML5 game
  type              String     // molecule-builder, physics-sim, etc.
  createdAt         DateTime   @default(now())

  topic             Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sessions          GameSession[]

  @@index([topicId])
}

// GameSession model - stores game play sessions
model GameSession {
  id                String     @id @default(cuid())
  userId            String
  gameId            String
  score             Int
  level             Int
  timeSpent         Int        // Seconds
  completed         Boolean    @default(false)
  playedAt          DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game              Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameId])
}

// FlashcardSet model - stores flashcard sets
model FlashcardSet {
  id                String     @id @default(cuid())
  subjectId         String
  title             String
  cards             Json       // Array of flashcard objects
  createdAt         DateTime   @default(now())

  subject           Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  reviews           FlashcardReview[]

  @@index([subjectId])
}

// FlashcardReview model - stores spaced repetition data
model FlashcardReview {
  id                String     @id @default(cuid())
  userId            String
  flashcardSetId    String
  cardId            String
  difficulty        String     // easy, medium, hard
  nextReviewAt      DateTime
  reviewedAt        DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcardSet      FlashcardSet @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([flashcardSetId])
  @@index([nextReviewAt])
}

// StudyPlan model - stores study plans and schedules
model StudyPlan {
  id                String     @id @default(cuid())
  userId            String
  goals             String
  hoursPerWeek      Int
  tips              Json       // Array of tip strings
  createdAt         DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions          StudySession[]
  milestones        Milestone[]

  @@index([userId])
}

// StudySession model - individual study sessions in a plan
model StudySession {
  id                String     @id @default(cuid())
  planId            String
  subjectId         String
  day               String     // Monday, Tuesday, etc.
  topic             String
  duration          Int        // minutes
  timeSlot          String     // Morning, Afternoon, Evening
  activities        Json       // Array of activity strings
  completed         Boolean    @default(false)
  createdAt         DateTime   @default(now())

  plan              StudyPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subject           Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([subjectId])
}

// Milestone model - study plan milestones
model Milestone {
  id                String     @id @default(cuid())
  planId            String
  subjectId         String
  title             String
  description       String
  dueDate           DateTime
  completed         Boolean    @default(false)
  createdAt         DateTime   @default(now())

  plan              StudyPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subject           Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([subjectId])
}

// Streak model - tracks daily learning streaks
model Streak {
  id                String     @id @default(cuid())
  userId            String     @unique
  currentStreak     Int        @default(0)
  longestStreak     Int        @default(0)
  lastActivityDate  DateTime

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Achievement model - stores unlocked achievements
model Achievement {
  id                String     @id @default(cuid())
  userId            String
  type              String     // quiz_master, streak_champion, etc.
  title             String
  description       String
  icon              String
  xp                Int        @default(0)
  unlockedAt        DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
